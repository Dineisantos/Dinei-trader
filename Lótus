    "BTC 📈 CALL",
    "BTC 📉 PUT",
    "EUR/USD 📈 CALL",
    "EUR/USD 📉 PUT"
  ];

  let s = sinais[Math.floor(Math.random()*sinais.length)];
  document.getElementById("sinal").innerText = s + " - 70%";
}
</script></body>
</html>
