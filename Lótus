<!DOCTYPE html><html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Dinei Trade 3D PRO</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body {
  font-family: Arial;
  text-align: center;
  background: linear-gradient(to bottom right, #0f172a, #2563eb);
  color: white;
}
button {
  padding: 15px;
  border-radius: 10px;
  border: none;
  margin-top: 20px;
